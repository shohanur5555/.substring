String captilize(String text){
  List<String> words = text.trim().split(RegExp(r'\s+'));
  List<String> result = [];
  
  for(var word in words){
    if(word.isNotEmpty){
      String cap = word.substring(0,1).toUpperCase() + word.substring(1).toLowerCase();
      result.add(cap);
    }
  }
  return result.join(" ");
}
void main(){
  print(captilize("hello flutter"));
}
