bool exists(String text, String containt) {
  for (int i = 0; i < text.length - containt.length; i++) {
    if (text.substring(i, i + containt.length) == containt) {
      return true;
    }
  }
  return false;
}

void main() {
  if (exists("programming", "gram") == true) {
    print("This word is existing..");
  } else {
    print("This word is not existing");
  }
}
