bool existing(String text, String containt){
  for(int i = 0; i <= text.length - containt.length; i++){
    if(text.substring(i, i+containt.length) == containt){
      return true;
    }
  }
  return false;
}
void main(){
  if(existing("programming","ming") == true){
    print("Yes! this word is existing");
  }
  else{
    print("No! this word is not existing");
  }
}
